{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/careers/layout,_N_T_/careers/[slug]/layout,_N_T_/careers/[slug]/page,_N_T_/careers/quality-assurance-specialist"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/careers/$d$slug/__PAGE__",
    "/careers/$d$slug",
    "/careers",
    "/_index",
    "/_head"
  ]
}