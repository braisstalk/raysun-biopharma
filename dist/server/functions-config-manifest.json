{
  "version": 1,
  "functions": {
    "/_middleware": {
      "runtime": "nodejs",
      "matchers": [
        {
          "regexp": "^(?:\\/(_next\\/data\\/[^/]{1,}))?(?:\\/((?!_next|favicon.ico|sitemap.xml|robots.txt|api|images).*))(\\.json)?[\\/#\\?]?$",
          "originalSource": "/((?!_next|favicon.ico|sitemap.xml|robots.txt|api|images).*)"
        }
      ]
    }
  }
}